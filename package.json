{
  "name": "fal-nano-mcp",
  "version": "1.3.0",
  "description": "MCP server for generating and editing images using Nano Banana 2 via Fal AI",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "fal-nano-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "start:sse": "node dist/index.js --sse",
    "dev": "tsx src/index.ts",
    "dev:sse": "tsx src/index.ts --sse"
  },
  "keywords": [
    "mcp",
    "fal",
    "nano-banana",
    "image-generation",
    "ai",
    "model-context-protocol"
  ],
  "author": "Daniel Rosehill",
  "license": "MIT",
  "dependencies": {
    "@fal-ai/client": "^1.2.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "express": "^5.1.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danielrosehill/Fal-Nano-MCP.git"
  }
}
